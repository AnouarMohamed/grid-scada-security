          },
          "query": "base = from(bucket: \"gridguard_telemetry\")\n  |> range(start: v.timeRangeStart, stop: v.timeRangeStop)\n  |> filter(fn: (r) => r._measurement == \"grid_telemetry\")\n  |> filter(fn: (r) => r._field == \"value\" and r.signal == \"voltage_pu\")\n\nunion(tables: [\n  base |> group() |> aggregateWindow(every: v.windowPeriod, fn: min, createEmpty: false) |> set(key: \"stat\", value: \"min\"),\n  base |> group() |> aggregateWindow(every: v.windowPeriod, fn: mean, createEmpty: false) |> set(key: \"stat\", value: \"mean\"),\n  base |> group() |> aggregateWindow(every: v.windowPeriod, fn: max, createEmpty: false) |> set(key: \"stat\", value: \"max\")\n])\n  |> group(columns: [\"stat\"])\n  |> yield(name: \"voltage_envelope\")",
