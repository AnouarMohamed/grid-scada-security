# GridGuard local fake-data stack.
#
# Copy to .env for local overrides. The defaults in compose.yaml are safe for
# local development only; do not reuse these values in shared or cloud systems.

GRIDGUARD_FEEDER_ID=ieee-13-demo
GRIDGUARD_SCENARIO=baseline-fake
GRIDGUARD_INGEST_INTERVAL_SECONDS=2

INFLUXDB_IMAGE=influxdb:2.7
INFLUXDB_PORT=8086
INFLUXDB_ORG=gridguard
INFLUXDB_BUCKET=gridguard_telemetry
INFLUXDB_ADMIN_USER=gridguard
INFLUXDB_ADMIN_PASSWORD=change-this-local-influx-password
INFLUXDB_ADMIN_TOKEN=change-this-local-influx-token

GRAFANA_IMAGE=grafana/grafana:11.5.2
GRAFANA_PORT=3000
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=change-this-local-grafana-password
